# ─── Native splash & launcher icon regenerated assets ──────────
# Keep the source icon (assets/icons/app_icon.png) but ignore the
# many generated platform-specific copies produced by
# flutter_launcher_icons / flutter_native_splash on each run.
android/app/src/main/res/mipmap-*/ic_launcher*.png
android/app/src/main/res/drawable-*/launch_image.png
android/app/src/main/res/drawable-*/background.png
android/app/src/main/res/values*/styles.xml.bak
ios/Runner/Assets.xcassets/LaunchImage.imageset/
ios/Runner/Assets.xcassets/AppIcon.appiconset/Icon-App-*.png

